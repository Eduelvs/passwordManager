# Cópia local: renomeie/copie para `.env` (não vai para o Git).
#
# Na Railway, defina as MESMAS chaves em Settings → Variables (não precisa de arquivo .env lá).

# Obrigatório — Postgres (na Railway vem do plugin ou você cola a URL)
DATABASE_URL="postgresql://USUARIO:SENHA@host:5432/nome_do_banco?schema=public"

# Obrigatório — segredo do JWT (gere uma string longa e aleatória)
JWT_SECRET=

# Opcional — local use a porta que quiser; na Railway o PORT costuma ser injetado automaticamente
# PORT=3001
