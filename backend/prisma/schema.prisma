generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  typeUser     UserRole   @default(user)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  passwords    Password[]
}

model Password {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  username  String?
  secret    String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
